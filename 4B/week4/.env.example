# Copy this file to the repository root as .env and fill in your values.
# Required: app will not start without a valid PostgreSQL URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Twilio (needed to send WhatsApp replies)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238xxx

# Required for AI responses (Gemini); without it, bot uses keyword fallback and hardcoded text
GOOGLE_API_KEY=

# Optional
LOG_LEVEL=INFO
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary
# Stripe API keys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
 
# Google APIs
GOOGLE_APPLICATION_CREDENTIALS=